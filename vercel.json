{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|assets|favicon.ico)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "outputDirectory": "public",
    "headers": [
        {
            "source": "/(.*).tmx",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/xml"
                }
            ]
        }
    ]
}